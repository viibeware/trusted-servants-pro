# Required: Flask session signing key. Generate a strong random value.
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
TSP_SECRET_KEY=change-me

# Optional: seeded on first boot only (ignored after a user exists)
# TSP_ADMIN_USERNAME=admin
# TSP_ADMIN_PASSWORD=admin
# TSP_ADMIN_EMAIL=admin@example.com
