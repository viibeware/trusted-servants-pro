+@public_bp.route("/videostreamer/stream.m3u8")
+def videostreamer_manifest():
+    from . import video_streamer as vse
+    vs, _site = _videostreamer_active_stream()
+    mgr = vse.get_manager()
+    path = mgr.manifest_path
+    if not os.path.exists(path):
+        abort(404)
+    resp = send_from_directory(mgr.stream_dir, "stream.m3u8",
+                               mimetype="application/vnd.apple.mpegurl")
+    # HLS manifests must NOT be cached — the live playlist is rewritten
+    # every segment, and stale caches break playback for late joiners.
+    resp.headers["Cache-Control"] = "no-store, no-cache, must-revalidate, max-age=0"
+    resp.headers["Pragma"] = "no-cache"
+    resp.headers["Expires"] = "0"
+    return resp
+
+
+@public_bp.route("/videostreamer/<segname>")
+def videostreamer_segment(segname):
+    """Serve an HLS .ts segment. ffmpeg writes the manifest with
+    relative segment names (``seg_NNNNN.ts``) so the browser resolves
+    them against the manifest URL — meaning segments need to live at
+    ``/videostreamer/<basename>``, not under a subdirectory.
+
+    Paths are constrained to the ``seg_*.ts`` shape ffmpeg emits so
+    the route can't be coaxed into reading arbitrary files from the
+    stream directory. Flask's default string converter forbids slashes,
+    so directory traversal via ``..%2F`` is also blocked at routing
+    time — we double-check here as defense in depth."""
+    from . import video_streamer as vse
+    vs, _site = _videostreamer_active_stream()
+    if "/" in segname or ".." in segname or not segname.startswith("seg_") \
+            or not segname.endswith(".ts"):
+        abort(404)
+    mgr = vse.get_manager()
+    full = os.path.join(mgr.stream_dir, segname)
+    if not os.path.isfile(full):
+        abort(404)
+    resp = send_from_directory(mgr.stream_dir, segname,
+                               mimetype="video/MP2T")
+    # Segments are immutable once written (filenames are unique
+    # incrementing ints). A short cache window lets edge caches /
+    # the browser hold them while still allowing a fresh manifest
+    # to point at newer ones.
+    resp.headers["Cache-Control"] = "public, max-age=10"
+    return resp
+
+
