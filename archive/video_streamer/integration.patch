+# ── Browser-camera ingest WebSocket ────────────────────────────────
+# The admin's browser captures via getUserMedia, packs webm chunks with
+# MediaRecorder, and forwards each chunk as a binary WS frame here. We
+# spawn ffmpeg in pipe-input mode on the first frame and feed every
+# subsequent chunk into its stdin. When the WS closes (admin clicks
+# "Stop", or navigates away), we close stdin so ffmpeg flushes the
+# tail of the HLS playlist and exits cleanly.
+#
+# Auth: the WS handshake is a normal GET upgrade, so Flask-Login's
+# session cookie carries the user identity. We re-check admin role +
+# module-enabled inside the handler so a stale cookie can't grant
+# ingest after the module is turned off.
+
+def _register_video_streamer_ws():
+    """Wire the WS route only when flask-sock loaded successfully.
+    Kept in a function so the import-time decorator doesn't blow up
+    in environments where the optional dep isn't installed."""
+    from . import sock as _s
+    if _s is None:
+        return
+
+    @_s.route("/tspro/video-streamer/ws/ingest")
+    def video_streamer_ingest_ws(ws):
+        from . import video_streamer as vse
+        # Admin + module gate. The WS handshake already passed through
+        # the regular request pipeline, so current_user is populated.
+        s = _get_site_setting()
+        if not s or not s.video_streamer_enabled:
+            ws.close()
+            return
+        if not current_user.is_authenticated or not current_user.is_admin():
+            ws.close()
+            return
+
+        vs = _get_video_stream()
+        if vs.source_type != "browser":
+            # Don't silently turn on browser ingest while the row is
+            # configured for a different source — admin would be
+            # confused when the stream they set up disappears.
+            ws.close()
+            return
+
+        mgr = vse.get_manager()
+        ok, msg = mgr.start_pipe(vs)
+        if not ok:
+            try:
+                ws.send(f'{{"error": {msg!r}}}')
+            except Exception:
+                pass
+            ws.close()
+            return
+        vs.status = "running"
+        vs.pid = mgr.current_pid()
+        vs.last_started_at = datetime.utcnow()
+        vs.last_error = None
+        db.session.commit()
+
+        try:
+            while True:
+                data = ws.receive(timeout=30)
+                if data is None:
+                    # Client closed or timed out without sending a frame.
+                    break
+                if isinstance(data, (bytes, bytearray)):
+                    if not mgr.write_chunk(data):
+                        # ffmpeg died — surface a hint and break.
+                        try:
+                            ws.send('{"error": "ffmpeg exited unexpectedly"}')
+                        except Exception:
+                            pass
+                        break
+                # String frames are control messages — we don't define
+                # any yet, so ignore them silently.
+        finally:
+            mgr.close_pipe()
+            vs.status = "stopped"
+            vs.pid = None
+            vs.last_stopped_at = datetime.utcnow()
+            try:
+                db.session.commit()
+            except Exception:
+                db.session.rollback()
+
+
+_register_video_streamer_ws()
+
