+class VideoStream(db.Model):
+    """Singleton: video streamer source + runtime status.
+
+    One logical "stream" per portal — admin picks a source (v4l2 device,
+    RTSP URL, HTTP URL, or local file) and starts/stops it from the
+    Video Streamer admin page. The streaming engine (app/video_streamer.py)
+    spawns an ffmpeg subprocess that ingests the source and writes HLS
+    segments to ``$TSP_DATA_DIR/stream/``; the public ``/videostreamer``
+    viewer plays the manifest via hls.js.
+    """
+    __tablename__ = "video_stream"
+    id = db.Column(db.Integer, primary_key=True)
+    # Source configuration. ``source_type`` is one of: device | rtsp |
+    # http | file | browser. ``source_path`` is the literal path or
+    # URL passed to ffmpeg's input (we don't quote it — ffmpeg handles
+    # its own parsing). ``browser`` ignores source_path; the source is
+    # the admin's webcam piped in over a WebSocket. Empty/None means
+    # the stream isn't configured yet.
+    source_type = db.Column(db.String(16), nullable=False, default="device")
+    source_path = db.Column(db.String(1000))
+    # When the "Local file" source is fed by a browser-upload (rather
+    # than a path the admin types in), the UUID-prefixed filename
+    # stored under ``UPLOAD_FOLDER`` lives here. The save handler sets
+    # ``source_path`` to the file's absolute path so ffmpeg can find
+    # it without the admin re-typing anything.
+    uploaded_video_filename = db.Column(db.String(500))
+    # Optional extra ffmpeg input args (advanced; e.g. -framerate 30
+    # -video_size 1280x720). Inserted before -i in the command line.
+    source_input_args = db.Column(db.String(500))
+    # Output encoding knobs. Sane defaults that work for webcam / OBS
+    # Virtual Cam through 1080p. Bitrate is the H.264 video bitrate
+    # ffmpeg targets; framerate caps the output (lower than the source
+    # to save bandwidth on slow connections).
+    video_width = db.Column(db.Integer, nullable=False, default=1920)
+    video_height = db.Column(db.Integer, nullable=False, default=1080)
+    framerate = db.Column(db.Integer, nullable=False, default=30)
+    bitrate_kbps = db.Column(db.Integer, nullable=False, default=2000)
