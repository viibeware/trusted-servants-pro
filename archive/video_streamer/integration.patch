+def _videostreamer_active_stream():
+    """Return the (stream, site) tuple if the streamer is enabled, or
+    abort(404) so the route + manifest URLs disappear when the module
+    is off. Keeps the per-handler boilerplate small."""
+    s = _get_site_setting()
+    if not s or not s.video_streamer_enabled:
+        abort(404)
