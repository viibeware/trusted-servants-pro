+def _get_video_stream():
+    """Resolve (or lazily create) the singleton VideoStream row."""
+    vs = VideoStream.query.first()
+    if not vs:
+        vs = VideoStream()
+        db.session.add(vs)
+        db.session.commit()
+    return vs
+
