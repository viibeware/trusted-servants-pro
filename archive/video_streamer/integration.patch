+_VIDEO_UPLOAD_EXTS = {".mp4", ".mov", ".mkv", ".webm", ".avi", ".m4v", ".mpeg", ".mpg", ".ogv"}
+
+
+@bp.route("/video-streamer/save", methods=["POST"])
+@admin_required
+def video_streamer_save():
+    from . import video_streamer as vse
+    import uuid as _uuid
+    vs = _get_video_stream()
+    stype = (request.form.get("source_type") or "").strip().lower()
+    if stype not in vse.SOURCE_TYPES:
+        stype = "device"
+    vs.source_type = stype
+    vs.source_input_args = (request.form.get("source_input_args") or "").strip() or None
+    vs.stream_title = (request.form.get("stream_title") or "").strip() or None
+    vs.stream_description = (request.form.get("stream_description") or "").strip() or None
+    vs.offline_message = (request.form.get("offline_message") or "").strip() or None
+    vs.include_audio = request.form.get("include_audio") == "1"
+    vs.auto_start = request.form.get("auto_start") == "1"
+
+    # File upload for the "Local file" source. The picker is part of
+    # the same form so save handles both the metadata + the file in
+    # one shot. The uploaded file is stored UUID-prefixed in
+    # UPLOAD_FOLDER (same pattern every other module upload uses);
+    # the row's source_path is auto-populated with the absolute path
+    # so ffmpeg can read it without the admin re-typing anything.
+    uploaded = request.files.get("uploaded_video")
+    if uploaded and uploaded.filename:
+        original = secure_filename(uploaded.filename) or "video"
+        ext = os.path.splitext(original)[1].lower()
+        if ext not in _VIDEO_UPLOAD_EXTS:
+            flash(f"Unsupported video extension {ext!r}. Allowed: "
+                  + ", ".join(sorted(_VIDEO_UPLOAD_EXTS)), "danger")
+            return redirect(url_for("main.video_streamer"))
+        stored = f"{_uuid.uuid4().hex}{ext}"
+        dest = os.path.join(current_app.config["UPLOAD_FOLDER"], stored)
+        uploaded.save(dest)
+        # Drop the prior upload so the uploads dir doesn't grow each
+        # time the admin replaces the source file.
+        prior = vs.uploaded_video_filename
+        if prior and prior != stored:
+            old = os.path.join(current_app.config["UPLOAD_FOLDER"], prior)
+            try:
+                os.remove(old)
+            except OSError:
+                pass
+        vs.uploaded_video_filename = stored
+        vs.source_path = dest
+    else:
+        # No new upload — accept the text path field (preserves the
+        # advanced "type your own path / lavfi testsrc" workflow).
+        text_path = (request.form.get("source_path") or "").strip()
+        if stype == "file" and vs.uploaded_video_filename and not text_path:
+            # The user has a previously-uploaded file selected and
+            # left the text field blank — keep using the upload.
+            vs.source_path = os.path.join(
+                current_app.config["UPLOAD_FOLDER"], vs.uploaded_video_filename)
+        else:
+            vs.source_path = text_path or None
+
+    def _int_or(default, lo, hi):
+        try:
+            v = int(default)
+        except (TypeError, ValueError):
+            return None
+        return max(lo, min(v, hi))
+
+    w = _int_or(request.form.get("video_width") or "1280", 160, 3840)
+    h = _int_or(request.form.get("video_height") or "720", 120, 2160)
+    fps = _int_or(request.form.get("framerate") or "30", 5, 60)
+    br = _int_or(request.form.get("bitrate_kbps") or "2500", 200, 20000)
+    if w: vs.video_width = w
+    if h: vs.video_height = h
+    if fps: vs.framerate = fps
+    if br: vs.bitrate_kbps = br
+
+    db.session.commit()
+    flash("Video Streamer settings saved", "success")
+    return redirect(url_for("main.video_streamer"))
+
